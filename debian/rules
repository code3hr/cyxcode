#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_clean:
	rm -rf node_modules
	rm -rf packages/opencode/node_modules
	rm -rf packages/opencode/dist

override_dh_auto_build:
	# Bun is installed via postinst if not present
	@echo "Build will be performed during package installation"

override_dh_auto_install:
	# Create directory structure
	mkdir -p debian/cyxcode/usr/lib/cyxcode
	mkdir -p debian/cyxcode/usr/bin
	mkdir -p debian/cyxcode/usr/share/doc/cyxcode
	mkdir -p debian/cyxcode/usr/share/man/man1

	# Copy source files
	cp -r packages debian/cyxcode/usr/lib/cyxcode/
	cp -r docs debian/cyxcode/usr/lib/cyxcode/
	cp package.json debian/cyxcode/usr/lib/cyxcode/
	cp bun.lock debian/cyxcode/usr/lib/cyxcode/ 2>/dev/null || true
	cp tsconfig.json debian/cyxcode/usr/lib/cyxcode/ 2>/dev/null || true

	# Copy documentation
	cp README.md debian/cyxcode/usr/share/doc/cyxcode/
	cp LICENSE debian/cyxcode/usr/share/doc/cyxcode/ 2>/dev/null || true

	# Install man page
	cp debian/cyxcode.1 debian/cyxcode/usr/share/man/man1/

override_dh_auto_test:
	@echo "Skipping tests during package build"
